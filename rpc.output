http endpoints: none
json_rpc methods: rpc_access_tracking
request fields (inherits rpc_request_base): clear: bool
response fields (inherits rpc_response_base): data: std::vector<entry>
nested types:
  - entry: rpc: std::string, count: uint64_t, time: uint64_t, credits: uint64_t

