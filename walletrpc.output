response fields (alias of split_transfer_response): tx_hash_list: std::list<std::string>, tx_key_list: std::list<std::string>, amount_list: std::list<uint64_t>, amounts_by_dest_list: std::list<amounts_list>, fee_list: std::list<uint64_t>, weight_list: std::list<uint64_t>, tx_blob_list: std::list<std::string>, tx_metadata_list: std::list<std::string>, multisig_txset: std::string, unsigned_txset: std::string, spent_key_images_list: std::list<key_image_list>

